rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de perfil dos usuários
    match /users/{userId}/avatar/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 5 * 1024 * 1024 && // máx 5MB
        request.resource.contentType.matches('image/.*');
    }

    // Arquivos compartilhados nas salas
    match /rooms/{roomId}/files/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.resource.size < 20 * 1024 * 1024; // máx 20MB
    }

    // Arquivos no chat
    match /conversations/{convoId}/files/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.resource.size < 10 * 1024 * 1024; // máx 10MB
    }
  }
}
